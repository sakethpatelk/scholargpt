# Copy this file to .env and fill in your values.
#
# LLM backend priority (LLM_BACKEND=auto):
#   auto      — Anthropic if key set, else Ollama if running, else retrieval-only
#   anthropic — force Claude API (requires ANTHROPIC_API_KEY)
#   ollama    — force local Ollama (must have `ollama serve` running)
#   none      — retrieval-only, no LLM
LLM_BACKEND=auto

# Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model selection (default is fine for most use cases)
CLAUDE_MODEL=claude-opus-4-8

# Sentence-transformers embedding model (downloaded automatically on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking parameters
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval parameters
TOP_K=5
RERANK_TOP_K=3
USE_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ChromaDB collection name
CHROMA_COLLECTION=research_papers

# Ollama local LLM (only needed if LLM_BACKEND=ollama or auto without API key)
# Install: https://ollama.com  →  ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
