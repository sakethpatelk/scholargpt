# Copy this file to .env and fill in your values.
#
# LLM backend:
#   auto   — use Ollama if running, else retrieval-only (default)
#   ollama — force local Ollama
#   none   — retrieval-only, never call an LLM
LLM_BACKEND=auto

# Ollama local LLM
# Install: https://ollama.com  ->  ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Sentence-transformers embedding model (downloaded automatically on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking parameters
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval parameters
TOP_K=5
RERANK_TOP_K=3
USE_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ChromaDB collection name
CHROMA_COLLECTION=research_papers
